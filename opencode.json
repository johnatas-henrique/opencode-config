{
  "$schema": "https://opencode.ai/config.json",
  "server": {
    "port": 4096,
    "hostname": "0.0.0.0",
    "mdns": true,
    "cors": [
      "http://localhost"
    ]
  },
  "permission": {
    "skill": {
      "*": "allow"
    },
    "tool": {
      "*": "allow"
    },
    "task": {
      "*": "allow"
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ]
    },
    "markitdown": {
      "type": "local",
      "enabled": true,
      "command": [
        "uvx",
        "markitdown-mcp"
      ]
    },
    "tavily": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "-y",
        "tavily-mcp"
      ],
      "environment": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      }
    },
    "thinking": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "context7": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      }
    }
  },
  "plugin": [
    "@gotgenes/opencode-agent-identity",
    "opencode-handoff"
  ]
}