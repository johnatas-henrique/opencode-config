{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "~/.config/opencode/AGENTS.md",
    "~/.config/opencode/docs/agent-instructions/memory-usage.md"
  ],
  "model": "opencode/big-pickle",
  "small_model": "openrouter/openrouter/elephant-alpha",
  "mcp": {
    "context7": {
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "exa": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp"
    },
    "gh_grep": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "markitdown": {
      "command": ["uvx", "markitdown-mcp@latest"],
      "enabled": true,
      "type": "local"
    },
    "playwright": {
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true,
      "type": "local"
    },
    "thinking": {
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking@latest"],
      "enabled": true,
      "type": "local"
    },
    "codebase-memory-mcp": {
      "enabled": true,
      "type": "local",
      "command": ["/home/johnatas/.local/bin/codebase-memory-mcp"]
    }
  },
  "permission": {
    "external_directory": {
      "*": "ask",
      "/tmp": "allow",
      "/tmp/*": "allow"
    },
    "skill": "allow",
    "task": {
      "*": "allow"
    },
    "tool": {
      "*": "allow"
    },
    "bash": {
      "*": "allow",
      "rm -rf *": "ask",
      "dd *": "ask",
      "git checkout *": "ask",
      "git reset *": "ask",
      "git restore *": "ask",
      "git clean *": "ask",
      "sh -c *": "ask"
    }
  },
  "plugin": [
    "opencode-handoff",
    "opencode-session-recall",
    "@gotgenes/opencode-agent-identity",
    "@knikolov/opencode-plugin-simple-memory",
    "@franlol/opencode-md-table-formatter@latest",
    "@cortexkit/opencode-magic-context",
    "rtk"
  ],
  "provider": {
    "manifest": {
      "models": {
        "auto": {
          "id": "auto",
          "limit": { "context": 1000000, "output": 120000 },
          "name": "Manifest Auto (Routed 1M context)"
        }
      },
      "name": "Manifest Build",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "{env:MANIFEST_API_KEY}",
        "baseURL": "https://app.manifest.build/v1"
      }
    },
