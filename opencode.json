{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "~/.config/opencode/AGENTS.md",
    "~/.config/opencode/docs/agent-instructions/memory-usage.md"
  ],
  "model": "manifest/auto",
  "small_model": "openrouter/elephant-alpha",
  "mcp": {
    "context7": {
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "exa": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp"
    },
    "gh_grep": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "lean-ctx": {
      "command": ["lean-ctx"],
      "enabled": true,
      "environment": { "LEAN_CTX_DATA_DIR": "/home/johnatas/.lean-ctx" },
      "type": "local"
    },
    "markitdown": {
      "command": ["uvx", "markitdown-mcp@latest"],
      "enabled": true,
      "type": "local"
    },
    "playwright": {
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true,
      "type": "local"
    },
    "thinking": {
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking@latest"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "permission": {
    "external_directory": { "*": "ask", "/tmp": "allow", "/tmp/*": "allow" },
    "skill": "allow",
    "task": { "*": "allow" },
    "tool": { "*": "allow" }
  },
  "plugin": [
    "opencode-handoff",
    "opencode-session-recall",
    "@gotgenes/opencode-agent-identity",
    "@knikolov/opencode-plugin-simple-memory",
    "@franlol/opencode-md-table-formatter@latest",
    "@cortexkit/opencode-magic-context"
  ],
  "provider": {
    "manifest": {
      "models": {
        "auto": {
          "id": "auto",
          "limit": {
            "context": 1000000,
            "output": 120000
          },
          "name": "Manifest Auto (Routed 1M context)"
        }
      },
      "name": "Manifest Build",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "{env:MANIFEST_API_KEY}",
        "baseURL": "https://app.manifest.build/v1"
      }
    },
    "omniroute": {
      "models": {
        "claude-haiku-4.5": {
          "attachment": true,
          "id": "kr/claude-haiku-4.5",
          "limit": {
            "context": 200000,
            "output": 8192
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          },
          "name": "Claude Haiku 4.5 (Kiro AI - Gratis)"
        },
        "claude-sonnet-4.5": {
          "attachment": true,
          "id": "kr/claude-sonnet-4.5",
          "limit": {
            "context": 200000,
            "output": 8192
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          },
          "name": "Claude Sonnet 4.5 (Kiro AI - Gratis)"
        },
        "cloudflare-llama-3.3-70b": {
          "attachment": true,
          "id": "cf/@cf/meta/llama-3.3-70b-instruct",
          "limit": {
            "context": 32768,
            "output": 8192
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          },
          "name": "Llama 3.3 70B (Cloudflare AI - Gratis)"
        },
        "cloudflare-qwen-coder": {
          "attachment": true,
          "id": "cf/@cf/qwen/qwen2.5-coder-15b-instruct",
          "limit": {
            "context": 32768,
            "output": 8192
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          },
          "name": "Qwen2.5 Coder 15B (Cloudflare AI - Gratis)"
        },
        "gemini-2.5-flash": {
          "attachment": true,
          "id": "gc/gemini-2.5-flash",
          "limit": {
            "context": 1000000,
            "output": 8192
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "name": "Gemini 2.5 Flash (180K/mes - Gratis)"
        },
        "kimi-k2-thinking": {
          "attachment": true,
          "id": "if/kimi-k2-thinking",
          "limit": {
            "context": 32768,
            "output": 8192
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          },
          "name": "Kimi K2 Thinking (OmniRoute)"
        },
        "longcat-flash-lite": {
          "attachment": true,
          "id": "lc/LongCat-Flash-Lite",
          "limit": {
            "context": 32768,
            "output": 8192
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          },
          "name": "LongCat Flash Lite (50M tokens/dia - Gratis)"
        },
        "nvidia-llama-3.3-70b": {
          "attachment": true,
          "id": "nvidia/llama-3.3-70b-instruct",
          "limit": {
            "context": 128000,
            "output": 8192
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          },
          "name": "Llama 3.3 70B (NVIDIA NIM - Gratis)"
        },
        "openrouter-claude-sonnet": {
          "attachment": true,
          "id": "openrouter/anthropic/claude-3.5-sonnet",
          "limit": {
            "context": 200000,
            "output": 8192
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "name": "Claude 3.5 Sonnet (OpenRouter)"
        },
        "openrouter-deepseek-r1": {
          "attachment": true,
          "id": "openrouter/deepseek/deepseek-r1",
          "limit": {
            "context": 128000,
            "output": 8192
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          },
          "name": "DeepSeek R1 (OpenRouter)"
        },
        "openrouter-gpt-4o": {
          "attachment": true,
          "id": "openrouter/openai/gpt-4o",
          "limit": {
            "context": 128000,
            "output": 16384
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "name": "GPT-4o (OpenRouter)"
        },
        "openrouter-llama-3.3-70b": {
          "attachment": true,
          "id": "openrouter/meta-llama/llama-3.3-70b-instruct",
          "limit": {
            "context": 128000,
            "output": 8192
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          },
          "name": "Llama 3.3 70B (OpenRouter)"
        },
        "qwen3-coder-flash": {
          "attachment": true,
          "id": "qw/qwen3-coder-flash",
          "limit": {
            "context": 32768,
            "output": 8192
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          },
          "name": "Qwen3 Coder Flash (Qwen Code - Gratis)"
        },
        "qwen3-coder-next": {
          "attachment": true,
          "id": "qw/qwen3-coder-next",
          "limit": {
            "context": 32768,
            "output": 8192
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          },
          "name": "Qwen3 Coder Next (Qwen Code - Gratis)"
        },
        "qwen3-coder-plus-direct": {
          "attachment": true,
          "id": "qw/qwen3-coder-plus",
          "limit": {
            "context": 32768,
            "output": 8192
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          },
          "name": "Qwen3 Coder Plus (Qwen Code - Gratis)"
        }
      },
      "npm": "@ai-sdk/openai",
      "options": {
        "apiKey": "{env:OMNIROUTE_API_KEY}",
        "baseURL": "http://localhost:20128/v1",
        "compatibility": "strict"
      }
    },
    "regolo": {
      "models": {
        "gpt-oss-120b": {
          "cost": {
            "input": 1,
            "output": 4.2
          },
          "id": "gpt-oss-120b",
          "limit": {
            "context": 120000,
            "output": 90000
          },
          "name": "gpt-oss-120b",
          "options": {
            "include": ["reasoning.encrypted_content"],
            "parallel_tool_calls": true,
            "reasoningEffort": "high",
            "reasoningSummary": "auto",
            "temperature": 0.7,
            "textVerbosity": "low",
            "thinking": true,
            "tool_choice": "auto"
          }
        },
        "minimax-m2.5": {
          "cost": {
            "input": 0.6,
            "output": 3.8
          },
          "id": "minimax-m2.5",
          "limit": {
            "context": 130000,
            "output": 130000
          },
          "name": "minimax-m2.5",
          "options": {
            "include": ["reasoning.encrypted_content"],
            "parallel_tool_calls": true,
            "reasoningEffort": "high",
            "reasoningSummary": "auto",
            "temperature": 0.7,
            "textVerbosity": "low",
            "thinking": true,
            "tool_choice": "auto"
          }
        },
        "mistral-small-4-119b": {
          "cost": {
            "input": 0.5,
            "output": 2.1
          },
          "id": "mistral-small-4-119b",
          "limit": {
            "context": 120000,
            "output": 120000
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "name": "mistral-small-4-119b",
          "options": {
            "include": ["reasoning.encrypted_content"],
            "parallel_tool_calls": true,
            "reasoningEffort": "high",
            "reasoningSummary": "auto",
            "temperature": 0.7,
            "textVerbosity": "low",
            "thinking": true,
            "tool_choice": "auto"
          }
        },
        "qwen3-coder-next": {
          "cost": {
            "input": 0.5,
            "output": 2
          },
          "id": "qwen3-coder-next",
          "limit": {
            "context": 240000,
            "output": 120000
          },
          "name": "qwen3-coder-next",
          "options": {
            "parallel_tool_calls": true,
            "repetition_penalty": 1.05,
            "temperature": 0.5,
            "tool_choice": "auto",
            "top_k": 40,
            "top_p": 0.95
          },
          "reasoning": true,
          "tool_call": true
        },
        "qwen3.5-122b": {
          "cost": {
            "input": 1,
            "output": 4.2
          },
          "id": "qwen3.5-122b",
          "limit": {
            "context": 120000,
            "output": 120000
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "name": "qwen3.5-122b",
          "options": {
            "include": ["reasoning.encrypted_content"],
            "parallel_tool_calls": true,
            "reasoningEffort": "high",
            "reasoningSummary": "auto",
            "temperature": 0.7,
            "textVerbosity": "low",
            "thinking": true,
            "tool_choice": "auto"
          }
        }
      },
      "name": "Regolo",
      "npm": "@ai-sdk/openai",
      "options": {
        "baseURL": "https://api.regolo.ai/v1",
        "chunkTimeout": 600000,
        "headers": {
          "Accept": "application/json",
          "Authorization": "Bearer {env:REGOLO_AI_API_KEY}"
        },
        "name": "Regolo",
        "timeout": 1200000
      }
    }
  },
  "compaction": {
    "auto": false,
    "prune": false
  },
  "server": {
    "cors": ["http://localhost"],
    "hostname": "0.0.0.0",
    "mdns": true,
    "port": 4096
  },
  "watcher": {
    "ignore": [
      "node_modules/",
      "dist/",
      ".cargo/",
      "target/",
      ".git/**",
      "*cache*",
      ".sisyphus",
      ".venv",
      "venv",
      "target"
    ]
  }
}
