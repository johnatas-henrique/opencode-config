{
  "$schema": "https://raw.githubusercontent.com/cortexkit/opencode-magic-context/master/assets/magic-context.schema.json",
  "enabled": true,
  "ctx_reduce_enabled": true,
  "execute_threshold_percentage": 60,
  "auto_drop_tool_age": 50,
  "nudge_interval_tokens": 5000,

  "historian": {
    "model": "openrouter/openrouter/elephant-alpha",
    "fallback_models": [
      "openrouter/nvidia/nemotron-3-super-120b-a12b:free",
      "googleai/gemma-4-31b-it"
    ]
  },

  "dreamer": {
    "enabled": true,
    "model": "googleai/gemma-4-31b-it",
    "fallback_models": [
      "openrouter/nvidia/nemotron-3-super-120b-a12b:free"
    ],
    "schedule": "02:00-06:00"
  },

  "sidekick": {
    "enabled": false
  }
}
