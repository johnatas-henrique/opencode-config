{
  "$schema": "https://raw.githubusercontent.com/cortexkit/opencode-magic-context/master/assets/magic-context.schema.json",
  "enabled": true,
  "memory": { "enabled": false },
  "embedding": { "provider": "off" },
  "ctx_reduce_enabled": true,
  "execute_threshold_percentage": 60,
  "auto_drop_tool_age": 50,
  "nudge_interval_tokens": 5000,
  "historian": {
    "model": "nvidia/openai/gpt-oss-120b",
    "fallback_models": [
      "nvidia/meta/llama-4-scout-17b-16e-instruct",
      "nvidia/stepfun-ai/step-3.5-flash",
      "mistral/mistral-small-latest"
    ]
  },
  "dreamer": {
    "enabled": false,
    "model": "nvidia/openai/gpt-oss-120b",
    "fallback_models": [
      "mistral/devstral-latest",
      "mistral/codestral-latest",
      "mistral/mistral-tiny-latest",
      "nvidia/openai/gpt-oss-120b"
    ],
    "schedule": "02:00-06:00",
    "user_memories": { "enabled": false }
  },
  "sidekick": { "enabled": false, "model": "nvidia/stepfun-ai/step-3.5-flash" },
  "experimental": {
    "auto_search": { "enabled": false },
    "git_commit_indexing": { "enabled": false }
  }
}
